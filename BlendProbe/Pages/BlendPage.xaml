<Page
  x:Class="BlendProbe.Pages.BlendPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Loaded="Page_Loaded"
  mc:Ignorable="d">

  <!--
    Blend verification matrix. The shell (header + ScrollViewer + StackPanel host) is
    declared here; the 8 probe cards are built in code-behind (Page_Loaded) because
    each card's brush needs an effect factory + source binders that can't be expressed
    in XAML. See BlendPage.xaml.cs::AddCard + BuildPreview.
  -->
  <Grid Background="#FF1A1A1A">
    <ScrollViewer Padding="32,24,32,40">
      <StackPanel x:Name="CardHost" MaxWidth="780" Spacing="16">
        <TextBlock
          FontSize="32"
          FontWeight="Bold"
          Foreground="#FFFFFFFF"
          Text="Blend 验证矩阵" />
        <TextBlock
          FontSize="13"
          Foreground="#FF9ACDFF"
          Text="每张卡片独立验证 CustomEffectRuntimeNative 的一种采样/链路组合。预览区下层是彩色场景（供 backdrop 采样），上层覆盖层是效果输出。HLSL 行为每卡的 fxc 语法校验结果。"
          TextWrapping="Wrap" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Page>
