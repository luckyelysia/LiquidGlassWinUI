<Page
  x:Class="BlendProbe.Pages.MaskBindingPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  MaxWidth="5000"
  Loaded="Page_Loaded"
  mc:Ignorable="d">

  <!--
    Mask-binding diagnostic. Shell (header + ScrollViewer + StackPanel host) declared
    here; the three probe cards + legend are built in code-behind (Page_Loaded) because
    each card's brush carries an effect factory + source binders. See MaskBindingPage.xaml.cs.
  -->
  <Grid Background="#FF1A1A1A">
    <ScrollViewer Padding="32,24,32,40">
      <StackPanel
        x:Name="CardHost"
        MaxWidth="860"
        Spacing="16">
        <TextBlock
          FontSize="30"
          FontWeight="Bold"
          Foreground="#FFFFFFFF"
          Text="Mask 绑定诊断" />
        <TextBlock
          FontSize="13"
          Foreground="#FF9ACDFF"
          Text="单独核查 card 11 的开放问题：双源拓扑（mask=色route src0，背景=采样route src1）里 texture0 为何返回 mask 而非背景？背景到底在不在线？三张卡片各覆盖一个场景（带文字），用 Mode 滑块实时切换返回的输入。"
          TextWrapping="Wrap" />
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Page>
