<Page
  x:Class="BlendProbe.Pages.BackdropLatencyPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Background="Transparent"
  Loaded="Page_Loaded"
  mc:Ignorable="d">

  <Page.Resources>
    <SolidColorBrush x:Key="CardA" Color="#FFEF5350" />
    <SolidColorBrush x:Key="CardB" Color="#FFFFA726" />
    <SolidColorBrush x:Key="CardC" Color="#FF66BB6A" />
    <SolidColorBrush x:Key="CardD" Color="#FF42A5F5" />
    <SolidColorBrush x:Key="QuoteBg" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="Pal1" Color="#FF26C6DA" />
    <SolidColorBrush x:Key="Pal2" Color="#FFEC407A" />
    <SolidColorBrush x:Key="Pal3" Color="#FFAB47BC" />
    <SolidColorBrush x:Key="Pal4" Color="#FF7E57C2" />
    <SolidColorBrush x:Key="Pal5" Color="#FF5C6BC0" />
    <SolidColorBrush x:Key="Pal6" Color="#FF26A69A" />
    <SolidColorBrush x:Key="Pal7" Color="#FF9CCC65" />
    <SolidColorBrush x:Key="Pal8" Color="#FFFFCA28" />

    <Storyboard x:Name="RotateAnim" RepeatBehavior="Forever">
      <DoubleAnimation
        Storyboard.TargetName="RotateBox"
        Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
        From="0"
        To="360"
        Duration="0:0:3" />
    </Storyboard>
    <Storyboard
      x:Name="PulseAnim"
      AutoReverse="True"
      RepeatBehavior="Forever">
      <DoubleAnimation
        Storyboard.TargetName="PulseBox"
        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
        From="1"
        To="1.3"
        Duration="0:0:1" />
      <DoubleAnimation
        Storyboard.TargetName="PulseBox"
        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
        From="1"
        To="1.3"
        Duration="0:0:1" />
    </Storyboard>
    <Storyboard
      x:Name="BounceAnim"
      AutoReverse="True"
      RepeatBehavior="Forever">
      <DoubleAnimation
        Storyboard.TargetName="BounceDot"
        Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
        From="0"
        To="-26"
        Duration="0:0:0.8" />
    </Storyboard>
  </Page.Resources>

  <Grid>
    <!--  Column 0: the live, scrollable scene (identical to DemoPage)  -->
    <ScrollViewer
      x:Name="SceneScroller"
      HorizontalScrollBarVisibility="Disabled"
      HorizontalScrollMode="Disabled"
      VerticalScrollBarVisibility="Auto">
      <StackPanel Width="720">
        <!--  header banner  -->
        <Border
          Height="220"
          Padding="32"
          CornerRadius="0">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Offset="0" Color="#FF7E1FA8" />
              <GradientStop Offset="0.5" Color="#FF0E8AA7" />
              <GradientStop Offset="1" Color="#FF1357B0" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel VerticalAlignment="Center">
            <TextBlock
              FontSize="56"
              FontWeight="Bold"
              Foreground="White"
              Text="BACKDROP LATENCY" />
            <TextBlock
              Margin="0,8,0,0"
              FontSize="20"
              Foreground="#CCFFFFFF"
              Text="Raw backdrop passthrough — GaussianBlur @ B=0" />
          </StackPanel>
        </Border>

        <TextBlock
          Margin="32,24,32,8"
          FontSize="22"
          FontWeight="SemiBold"
          Text="Overview" />
        <TextBlock
          Margin="32,0,32,16"
          FontSize="15"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          Text="Drag the overlay over this scene. It renders the RAW backdrop through a GaussianBlurEffect at BlurAmount=0 — the simplest possible compositor path. If there is any inherent frame of latency in CreateBackdropBrush, it will show as a shift between the overlay content and the scene behind it when scrolling."
          TextWrapping="Wrap" />

        <!--  LIVE animated regions  -->
        <StackPanel Margin="32,8,32,12">
          <TextBlock
            Margin="0,0,0,10"
            FontSize="22"
            FontWeight="SemiBold"
            Text="Live" />
          <StackPanel
            Margin="0,0,0,12"
            Orientation="Horizontal"
            Spacing="18">
            <Border
              x:Name="RotateBox"
              Width="84"
              Height="84"
              CornerRadius="16"
              RenderTransformOrigin="0.5,0.5">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Offset="0" Color="#FF00E5FF" />
                  <GradientStop Offset="1" Color="#FF2979FF" />
                </LinearGradientBrush>
              </Border.Background>
              <Border.RenderTransform>
                <RotateTransform />
              </Border.RenderTransform>
            </Border>
            <Border
              x:Name="PulseBox"
              Width="84"
              Height="84"
              Background="#FFEC407A"
              CornerRadius="16"
              RenderTransformOrigin="0.5,0.5">
              <Border.RenderTransform>
                <ScaleTransform />
              </Border.RenderTransform>
            </Border>
            <Grid Width="84" Height="84">
              <Border
                x:Name="BounceDot"
                Width="44"
                Height="44"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Background="#FFB2FF59"
                CornerRadius="22">
                <Border.RenderTransform>
                  <TranslateTransform />
                </Border.RenderTransform>
              </Border>
            </Grid>
            <ProgressRing
              Width="60"
              Height="60"
              VerticalAlignment="Center"
              IsActive="True" />
          </StackPanel>
          <ProgressBar
            Height="14"
            CornerRadius="7"
            IsIndeterminate="True" />
        </StackPanel>

        <!--  coloured cards row  -->
        <Grid Margin="32,8,32,16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition Width="12" />
            <ColumnDefinition />
            <ColumnDefinition />
          </Grid.ColumnDefinitions>
          <Border
            Grid.Column="0"
            Height="120"
            Background="{StaticResource CardA}"
            CornerRadius="14" />
          <Border
            Grid.Column="1"
            Height="120"
            Background="{StaticResource CardB}"
            CornerRadius="14" />
          <Border
            Grid.Column="3"
            Height="120"
            Background="{StaticResource CardC}"
            CornerRadius="14" />
          <Border
            Grid.Column="4"
            Height="120"
            Background="{StaticResource CardD}"
            CornerRadius="14" />
        </Grid>

        <!--  quote  -->
        <Border
          Margin="32,8,32,20"
          Padding="28"
          Background="{StaticResource QuoteBg}"
          CornerRadius="16">
          <TextBlock
            FontSize="26"
            FontStyle="Italic"
            FontWeight="SemiBold"
            Text="&#x201C;Drag me over the text, the cards, the palette &#x2014; the raw backdrop should exactly match what is behind.&#x201D;"
            TextWrapping="Wrap" />
        </Border>

        <!--  colour palette  -->
        <TextBlock
          Margin="32,8,32,8"
          FontSize="22"
          FontWeight="SemiBold"
          Text="Palette" />
        <GridView
          Margin="32,0,32,16"
          IsHitTestVisible="False"
          SelectionMode="None">
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal1}" />
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal2}" />
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal3}" />
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal4}" />
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal5}" />
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal6}" />
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal7}" />
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal8}" />
        </GridView>

        <!--  faux hero image  -->
        <Border
          Height="240"
          Margin="32,8,32,20"
          CornerRadius="16">
          <Grid>
            <Grid.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0" Color="#FF102A43" />
                <GradientStop Offset="1" Color="#FF334E68" />
              </LinearGradientBrush>
            </Grid.Background>
            <Ellipse
              Width="220"
              Height="220"
              Margin="-60,-60,0,0"
              Fill="#88FFB300" />
            <Ellipse
              Width="260"
              Height="260"
              Margin="0,0,-80,-80"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Fill="#55EF5350" />
            <TextBlock
              Margin="24"
              FontSize="20"
              FontWeight="SemiBold"
              Foreground="#CCFFFFFF"
              Text="a faux hero image" />
          </Grid>
        </Border>

        <!--  lorem  -->
        <TextBlock
          Margin="32,8,32,8"
          FontSize="22"
          FontWeight="SemiBold"
          Text="Detail" />
        <TextBlock
          Margin="32,0,32,14"
          FontSize="15"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          Text="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat."
          TextWrapping="Wrap" />
        <TextBlock
          Margin="32,0,32,14"
          FontSize="15"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          Text="Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum. Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium."
          TextWrapping="Wrap" />
        <TextBlock
          Margin="32,0,32,40"
          FontSize="15"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          Text="Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit, sed quia consequuntur magni dolores eos qui ratione voluptatem sequi nesciunt."
          TextWrapping="Wrap" />
      </StackPanel>
    </ScrollViewer>

    <!--
      Overlay: draggable rectangle rendering RAW backdrop via GaussianBlur(0).
      Completely passthrough — no glass, no refraction, no custom shader.
    -->
    <Border
      x:Name="LatencyOverlay"
      Grid.Column="0"
      Width="320"
      Height="200"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      ManipulationDelta="Overlay_ManipulationDelta"
      ManipulationMode="All"
      ToolTipService.ToolTip="Drag me — raw backdrop">
      <Border.RenderTransform>
        <TranslateTransform x:Name="OverlayTransform" />
      </Border.RenderTransform>
    </Border>
  </Grid>
</Page>
