<?xml version="1.0" encoding="utf-8" ?>
<Page
  x:Class="LiquidGlassDemo.Pages.TabBarPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:lg="using:LiquidGlassWinUI"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Background="#181818"
  Loaded="Page_Loaded"
  mc:Ignorable="d">

  <Page.Resources>
    <SolidColorBrush x:Key="CardA" Color="#FFEF5350" />
    <SolidColorBrush x:Key="CardB" Color="#FFFFA726" />
    <SolidColorBrush x:Key="CardC" Color="#FF66BB6A" />
    <SolidColorBrush x:Key="CardD" Color="#FF42A5F5" />
    <SolidColorBrush x:Key="QuoteBg" Color="#22FFFFFF" />
    <SolidColorBrush x:Key="Pal1" Color="#FF26C6DA" />
    <SolidColorBrush x:Key="Pal2" Color="#FFEC407A" />
    <SolidColorBrush x:Key="Pal3" Color="#FFAB47BC" />
    <SolidColorBrush x:Key="Pal4" Color="#FF7E57C2" />
    <SolidColorBrush x:Key="Pal5" Color="#FF5C6BC0" />
    <SolidColorBrush x:Key="Pal6" Color="#FF26A69A" />
    <SolidColorBrush x:Key="Pal7" Color="#FF9CCC65" />
    <SolidColorBrush x:Key="Pal8" Color="#FFFFCA28" />

    <Storyboard x:Name="RotateAnim" RepeatBehavior="Forever">
      <DoubleAnimation
        Storyboard.TargetName="RotateBox"
        Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
        From="0"
        To="360"
        Duration="0:0:3" />
    </Storyboard>
    <Storyboard
      x:Name="PulseAnim"
      AutoReverse="True"
      RepeatBehavior="Forever">
      <DoubleAnimation
        Storyboard.TargetName="PulseBox"
        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
        From="1"
        To="1.3"
        Duration="0:0:1" />
      <DoubleAnimation
        Storyboard.TargetName="PulseBox"
        Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
        From="1"
        To="1.3"
        Duration="0:0:1" />
    </Storyboard>
    <Storyboard
      x:Name="BounceAnim"
      AutoReverse="True"
      RepeatBehavior="Forever">
      <DoubleAnimation
        Storyboard.TargetName="BounceDot"
        Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
        From="0"
        To="-26"
        Duration="0:0:0.8" />
    </Storyboard>

    <!--
      Tab bar radio-button style: children inherit Foreground from the RadioButton.
      CheckState drives ContentPresenter.Foreground; FontIcon/TextBlock inherit it.
    -->
    <Style x:Key="TabBarItemStyle" TargetType="RadioButton">
      <Setter Property="Width" Value="72" />
      <Setter Property="Height" Value="64" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="#99FFFFFF" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Grid>
              <ContentPresenter x:Name="ContentPresenter" />
              <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="CommonStates">
                  <VisualState x:Name="Normal" />
                  <VisualState x:Name="PointerOver">
                    <VisualState.Setters>
                      <Setter Target="ContentPresenter.Foreground" Value="#DDFFFFFF" />
                    </VisualState.Setters>
                  </VisualState>
                  <VisualState x:Name="Pressed">
                    <VisualState.Setters>
                      <Setter Target="ContentPresenter.Foreground" Value="#88FFFFFF" />
                    </VisualState.Setters>
                  </VisualState>
                </VisualStateGroup>
                <VisualStateGroup x:Name="CheckStates">
                  <VisualState x:Name="Checked">
                    <VisualState.Setters>
                      <Setter Target="ContentPresenter.Foreground" Value="#FFFFFF" />
                    </VisualState.Setters>
                  </VisualState>
                  <VisualState x:Name="Unchecked">
                    <VisualState.Setters>
                      <Setter Target="ContentPresenter.Foreground" Value="#99FFFFFF" />
                    </VisualState.Setters>
                  </VisualState>
                  <VisualState x:Name="Indeterminate" />
                </VisualStateGroup>
              </VisualStateManager.VisualStateGroups>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!--
      Indicator brush states — defined as resources so TransitionTo can
      read target values without manual parameter lists.
    -->
    <lg:LiquidGlassBrush
      x:Name="ReleasedBrush"
      BlurAmount="1.93"
      DispersionRange="0.39"
      GlareAngle="-135.00"
      GlareConvergence="100.00"
      GlareFactor="71.52"
      GlareHardness="13.00"
      GlareRange="36.13"
      RefDispersion="3.50"
      RefFactor="3.37"
      RefFresnelFactor="21.96"
      RefFresnelHardness="0.00"
      RefFresnelRange="57.84"
      RefThickness="0.00"
      ShapeRadius="1.00"
      ShapeRoundness="2.00"
      TintA="0.70" />

    <lg:LiquidGlassBrush
      x:Name="PressedBrush"
      BlurAmount="0.00"
      DispersionRange="0.32"
      GlareAngle="-125.92"
      GlareConvergence="100.00"
      GlareFactor="71.52"
      GlareHardness="13.00"
      GlareRange="20.44"
      Magnification="1.04"
      RefDispersion="9.94"
      RefFactor="1.21"
      RefFresnelFactor="23.25"
      RefFresnelHardness="3.64"
      RefFresnelRange="57.84"
      RefThickness="39.78"
      ShapeRadius="1.00"
      ShapeRoundness="2.00" />
  </Page.Resources>

  <Grid>
    <!--  Backdrop scene (same style as DevPage)  -->
    <ScrollViewer
      HorizontalScrollBarVisibility="Disabled"
      HorizontalScrollMode="Disabled"
      VerticalScrollBarVisibility="Auto">
      <StackPanel Width="720" Margin="0,0,0,90">

        <!--  Header banner  -->
        <Border
          Height="200"
          Padding="32"
          CornerRadius="0">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Offset="0" Color="#FF7E1FA8" />
              <GradientStop Offset="0.5" Color="#FF0E8AA7" />
              <GradientStop Offset="1" Color="#FF1357B0" />
            </LinearGradientBrush>
          </Border.Background>
          <StackPanel VerticalAlignment="Center">
            <TextBlock
              FontSize="56"
              FontWeight="Bold"
              Foreground="White"
              Text="TAB BAR" />
            <TextBlock
              Margin="0,8,0,0"
              FontSize="20"
              Foreground="#CCFFFFFF"
              Text="iOS-style glass tab bar with LiquidGlassBrush" />
          </StackPanel>
        </Border>

        <TextBlock
          Margin="32,24,32,8"
          FontSize="22"
          FontWeight="SemiBold"
          Text="Overview" />
        <TextBlock
          Margin="32,0,32,16"
          FontSize="15"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          Text="The tab bar at the bottom uses a LiquidGlassBrush that refracts the backdrop in real time. The glass samples whatever scrolls behind it -- gradients, animated shapes, cards, palette. Each parameter is bound and animated directly from the LiquidGlassWinUI NuGet package."
          TextWrapping="Wrap" />

        <!--  Live animated shapes  -->
        <StackPanel Margin="32,8,32,12">
          <TextBlock
            Margin="0,0,0,10"
            FontSize="22"
            FontWeight="SemiBold"
            Text="Live" />
          <StackPanel
            Margin="0,0,0,12"
            Orientation="Horizontal"
            Spacing="18">
            <Border
              x:Name="RotateBox"
              Width="84"
              Height="84"
              CornerRadius="16"
              RenderTransformOrigin="0.5,0.5">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Offset="0" Color="#FF00E5FF" />
                  <GradientStop Offset="1" Color="#FF2979FF" />
                </LinearGradientBrush>
              </Border.Background>
              <Border.RenderTransform>
                <RotateTransform />
              </Border.RenderTransform>
            </Border>
            <Border
              x:Name="PulseBox"
              Width="84"
              Height="84"
              Background="#FFEC407A"
              CornerRadius="16"
              RenderTransformOrigin="0.5,0.5">
              <Border.RenderTransform>
                <ScaleTransform />
              </Border.RenderTransform>
            </Border>
            <Grid Width="84" Height="84">
              <Border
                x:Name="BounceDot"
                Width="44"
                Height="44"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Background="#FFB2FF59"
                CornerRadius="22">
                <Border.RenderTransform>
                  <TranslateTransform />
                </Border.RenderTransform>
              </Border>
            </Grid>
            <ProgressRing
              Width="60"
              Height="60"
              VerticalAlignment="Center"
              IsActive="True" />
          </StackPanel>
          <ProgressBar
            Height="14"
            CornerRadius="7"
            IsIndeterminate="True" />
        </StackPanel>

        <!--  Colored cards  -->
        <Grid Margin="32,8,32,16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition Width="12" />
            <ColumnDefinition />
            <ColumnDefinition />
          </Grid.ColumnDefinitions>
          <Border
            Grid.Column="0"
            Height="120"
            Background="{StaticResource CardA}"
            CornerRadius="14" />
          <Border
            Grid.Column="1"
            Height="120"
            Background="{StaticResource CardB}"
            CornerRadius="14" />
          <Border
            Grid.Column="3"
            Height="120"
            Background="{StaticResource CardC}"
            CornerRadius="14" />
          <Border
            Grid.Column="4"
            Height="120"
            Background="{StaticResource CardD}"
            CornerRadius="14" />
        </Grid>

        <!--  Quote  -->
        <Border
          Margin="32,8,32,20"
          Padding="28"
          Background="{StaticResource QuoteBg}"
          CornerRadius="16">
          <TextBlock
            FontSize="26"
            FontStyle="Italic"
            FontWeight="SemiBold"
            Text="The tab bar glass samples the backdrop behind it -- the edges refract whatever scrolls past."
            TextWrapping="Wrap" />
        </Border>

        <!--  Palette  -->
        <TextBlock
          Margin="32,8,32,8"
          FontSize="22"
          FontWeight="SemiBold"
          Text="Palette" />
        <GridView
          Margin="32,0,32,16"
          IsHitTestVisible="False"
          SelectionMode="None">
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal1}" />
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal2}" />
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal3}" />
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal4}" />
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal5}" />
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal6}" />
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal7}" />
          <Border
            Width="90"
            Height="90"
            Background="{StaticResource Pal8}" />
        </GridView>

        <!--  Hero image  -->
        <Border
          Height="240"
          Margin="32,8,32,20"
          CornerRadius="16">
          <Grid>
            <Grid.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0" Color="#FF102A43" />
                <GradientStop Offset="1" Color="#FF334E68" />
              </LinearGradientBrush>
            </Grid.Background>
            <Ellipse
              Width="220"
              Height="220"
              Margin="-60,-60,0,0"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Fill="#88FFB300" />
            <Ellipse
              Width="260"
              Height="260"
              Margin="0,0,-80,-80"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Fill="#55EF5350" />
            <TextBlock
              Margin="24"
              FontSize="20"
              FontWeight="SemiBold"
              Foreground="#CCFFFFFF"
              Text="a faux hero image" />
          </Grid>
        </Border>

        <!--  Lorem  -->
        <TextBlock
          Margin="32,8,32,8"
          FontSize="22"
          FontWeight="SemiBold"
          Text="Detail" />
        <TextBlock
          Margin="32,0,32,14"
          FontSize="15"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          Text="Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat."
          TextWrapping="Wrap" />
        <TextBlock
          Margin="32,0,32,14"
          FontSize="15"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          Text="Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum. Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium."
          TextWrapping="Wrap" />
        <TextBlock
          Margin="32,0,32,40"
          FontSize="15"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          Text="Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit, sed quia consequuntur magni dolores eos qui ratione voluptatem sequi nesciunt."
          TextWrapping="Wrap" />
      </StackPanel>
    </ScrollViewer>

    <!--  Tab Bar overlay  -->
    <Border
      Width="600"
      Height="80"
      VerticalAlignment="Bottom">
      <Border.RenderTransform>
        <TranslateTransform Y="-20" />
      </Border.RenderTransform>
      <Border.Background>
        <lg:LiquidGlassBrush
          BlurAmount="1.93"
          DispersionRange="0.39"
          Exposure="0.6"
          GlareAngle="-135.00"
          GlareConvergence="100.00"
          GlareFactor="71.52"
          GlareHardness="13.00"
          GlareRange="36.13"
          RefDispersion="3.50"
          RefFactor="1.31"
          RefFresnelFactor="21.96"
          RefFresnelHardness="0.00"
          RefFresnelRange="57.84"
          RefThickness="22.52"
          ShapeRadius="1.00"
          ShapeRoundness="2.00" />


      </Border.Background>

      <Grid x:Name="TabBarGrid">
        <!--
          Slider indicator — LiquidGlass pill behind the tab buttons.
          Draggable to switch tabs; magnifies on press.
        -->
        <Border
          x:Name="TabIndicator"
          Width="120"
          Height="64"
          HorizontalAlignment="Left"
          VerticalAlignment="Center"
          CornerRadius="20"
          ManipulationDelta="Indicator_ManipulationDelta"
          ManipulationMode="TranslateX"
          PointerCaptureLost="Indicator_PointerCaptureLost"
          PointerMoved="Indicator_PointerMoved"
          PointerPressed="Indicator_PointerPressed"
          PointerReleased="Indicator_PointerReleased"
          RenderTransformOrigin="0.5,0.5">
          <Border.Background>
            <StaticResource ResourceKey="ReleasedBrush" />
          </Border.Background>
          <Border.RenderTransform>
            <TransformGroup>
              <ScaleTransform x:Name="IndicatorScale" ScaleX="1" ScaleY="1" />
              <TranslateTransform x:Name="IndicatorTransform" />
            </TransformGroup>
          </Border.RenderTransform>
        </Border>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
          </Grid.ColumnDefinitions>

          <!--  Tab: Home (checked by default)  -->
          <RadioButton
            Grid.Column="0"
            Checked="Tab_Checked"
            GroupName="TabBar"
            IsChecked="True"
            IsTabStop="False"
            Style="{StaticResource TabBarItemStyle}">
            <StackPanel
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Spacing="2">
              <FontIcon FontSize="22" Glyph="&#xE80F;" />
              <TextBlock FontSize="10" Text="Home" />
            </StackPanel>
          </RadioButton>

          <!--  Tab: Search  -->
          <RadioButton
            Grid.Column="1"
            Checked="Tab_Checked"
            GroupName="TabBar"
            IsTabStop="False"
            Style="{StaticResource TabBarItemStyle}">
            <StackPanel
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Spacing="2">
              <FontIcon FontSize="22" Glyph="&#xE721;" />
              <TextBlock FontSize="10" Text="Search" />
            </StackPanel>
          </RadioButton>

          <!--  Tab: Favorites  -->
          <RadioButton
            Grid.Column="2"
            Checked="Tab_Checked"
            GroupName="TabBar"
            IsTabStop="False"
            Style="{StaticResource TabBarItemStyle}">
            <StackPanel
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Spacing="2">
              <FontIcon FontSize="22" Glyph="&#xEB51;" />
              <TextBlock FontSize="10" Text="Favorites" />
            </StackPanel>
          </RadioButton>

          <!--  Tab: Profile  -->
          <RadioButton
            Grid.Column="3"
            Checked="Tab_Checked"
            GroupName="TabBar"
            IsTabStop="False"
            Style="{StaticResource TabBarItemStyle}">
            <StackPanel
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Spacing="2">
              <FontIcon FontSize="22" Glyph="&#xE77B;" />
              <TextBlock FontSize="10" Text="Profile" />
            </StackPanel>
          </RadioButton>
        </Grid>
      </Grid>
    </Border>

  </Grid>
</Page>
